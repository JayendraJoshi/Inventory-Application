<html lang="en">
    <head>
        <meta charset="UTF-8">
        <title>Inventory App</title>
        <link rel="stylesheet" href="/card-layout.css">
    </head>
<body>
    <div class="header-wrapper">
        <header>
            <%- include('partials/navbar') %>
        </header>
    </div>
    <div class="main-wrapper">
        <main>
            <form action="/genres/new" method="get">
                <button class="add-button" type="submit">Add new genre</button>
            </form>
            <div class="cards-container">
            <% if(!genres.length){ %>
                <p>No genres added yet!</p>
            <% } else{ %>
                <%  genres.forEach(genre=>{%>
                    <div class="card">
                        <div class="url-container">
                             <a href="/genres/<%= genre.id %>" class="card"><%= genre.name%></a>
                        </div>          
                        <div class="button-container">
                            <form action="genres/<%= genre.id %>/delete" method="post">
                                <button type="submit">Delete</button>
                            </form>
                        </div>
                    </div>
                    <% })%>
                <% } %>
            </div>
        </main>
        </div>
    <div class="footer-wrapper">
        <%-include('partials/footer')%>
    </div>  
</body>
</html>