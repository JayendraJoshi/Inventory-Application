<html lang="en">
    <head>
        <meta charset="UTF-8">
        <title>Inventory App</title>
    <link rel="stylesheet" href="/table-layout.css" />
    </head>
    <body>
        <div class="header-wrapper">
             <header>
                <%- include('partials/navbar') %>
            </header>
        </div>
        <div class="main-wrapper">
             <main>
            <h1><%= genre.name %> movies</h1>
            <table>
                <thead>
                    <tr>
                        <th>Name</th>
                        <th>Modify</th>
                    </tr>
                    <tbody>
                        <% movies.forEach(movie=>{%>
                            <tr>
                                <th scope="row"><a href="/movies/<%= movie.id %>"><%= movie.name %></a></th>
                                <td>
                                    <form action="/movies/<%= movie.id %>/delete" method="POST">
                                    <button type="submit"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640"><!--!Font Awesome Free v7.3.1 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2026 Fonticons, Inc.--><path d="M232.7 69.9L224 96L128 96C110.3 96 96 110.3 96 128C96 145.7 110.3 160 128 160L512 160C529.7 160 544 145.7 544 128C544 110.3 529.7 96 512 96L416 96L407.3 69.9C402.9 56.8 390.7 48 376.9 48L263.1 48C249.3 48 237.1 56.8 232.7 69.9zM512 208L128 208L149.1 531.1C150.7 556.4 171.7 576 197 576L443 576C468.3 576 489.3 556.4 490.9 531.1L512 208z"/></svg></button>
                                </td>
                            </tr>
                       <% }) %>
                    </tbody>
                </thead>
            </table>
        </main>
        </div>
        <div class="footer-wrapper">
            <%-include('partials/footer')%>
        </div>
    </body>
</html>